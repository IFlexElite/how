# ── REQUIRED — set these as Railway Variables ─────────────────────────────────
# ⚠️  In Railway: Variable NAME = BOT_TOKEN,  VALUE = 123456:ABCdef...
#     Do NOT put the token itself as the variable name!

BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# From https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Your Telegram numeric ID  (find via @userinfobot)
OWNER_ID=987654321

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Railway sets PORT automatically; leave this as-is
PORT=8080

# Pyrogram session string for /names command (leave blank to disable /names)
# Get it from: @SessionStringBot  OR  @PyrogramV2Bot
USERBOT_SESSION=
